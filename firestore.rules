rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return signedIn() && userDoc(request.auth.uid).role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if ownsUserDoc(userId)
        && request.resource.data.xp == 0
        && request.resource.data.energy == 0
        && request.resource.data.totalScore == 0
        && (request.resource.data.role == 'user' || request.resource.data.role == 'admin');
      allow update: if ownsUserDoc(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'email',
          'createdAt',
          'role'
        ])
        || isAdmin();
      allow delete: if false;

      match /subjects/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /units/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /subUnits/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /lessons/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /questions/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /answers/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /files/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }

      match /forgeSources/{docId} {
        allow read, write: if ownsUserDoc(userId) || isAdmin();
      }
    }
  }
}
